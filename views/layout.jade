doctype html
html(lang="en")

  head

    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")

    title Asset Management System

    link(
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    )

    link(
      rel="stylesheet"
      href="https://cdn.datatables.net/2.3.2/css/dataTables.bootstrap5.css"
    )

  body

    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark

      .container-fluid

        a.navbar-brand(href="/assets")
          | Asset Management

        button.navbar-toggler(
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarNav"
          aria-controls="navbarNav"
          aria-expanded="false"
          aria-label="Toggle navigation"
        )
          span.navbar-toggler-icon

        .collapse.navbar-collapse#navbarNav

          ul.navbar-nav.me-auto

            li.nav-item
              a.nav-link(href="/employees") Employees

            li.nav-item
              a.nav-link(href="/categories") Categories

            li.nav-item
              a.nav-link(href="/assets") Assets

            li.nav-item
              a.nav-link(href="/stock") Stock View

            li.nav-item
              a.nav-link(href="/issue") Issue Asset

            li.nav-item
              a.nav-link(href="/return") Return Asset

            li.nav-item
              a.nav-link(href="/scrap") Scrap Asset

    .container.mt-4

      block content

    script(src="https://code.jquery.com/jquery-3.7.1.min.js")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")

    script(src="https://cdn.datatables.net/2.3.2/js/dataTables.js")
    script(src="https://cdn.datatables.net/2.3.2/js/dataTables.bootstrap5.js")

    script.

      document.addEventListener("DOMContentLoaded", function () {

        if (document.querySelector("#employeeTable")) {
          new DataTable("#employeeTable");
        }

        if (document.querySelector("#assetTable")) {
          new DataTable("#assetTable");
        }

        if (document.querySelector("#categoryTable")) {
          new DataTable("#categoryTable");
        }

        if (document.querySelector("#stockTable")) {
          new DataTable("#stockTable");
        }

        if (document.querySelector("#historyTable")) {
          new DataTable("#historyTable");
        }

      });