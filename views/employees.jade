extends layout

block content

  h1.mb-4 Employee List

  if message
    .alert.alert-success= message

  .row.mb-3

    .col-md-6.col-12.mb-2
      a.btn.btn-primary(href="/employees/add") Add Employee

    .col-md-6.col-12
      form(method="GET", action="/employees").row.g-2.justify-content-end

        .col-sm-8
          select.form-select(name="status")
            option(value="" selected=selectedStatus=="") All Employees
            option(value="active" selected=selectedStatus=="active") Active
            option(value="inactive" selected=selectedStatus=="inactive") Inactive

        .col-sm-4
          button.btn.btn-success.w-100(type="submit") Filter

  .table-responsive

    table.table.table-bordered.table-striped#employeeTable

      thead

        tr
          th Name
          th Email
          th Department
          th Status
          th Action

      tbody

        each emp in employees

          tr

            td= emp.name

            td= emp.email

            td= emp.department

            td
              if emp.status === "active"
                span.badge.bg-success Active
              else
                span.badge.bg-danger Inactive

            td

              a.btn.btn-warning.btn-sm.me-2(
                href="/employees/edit/" + emp.id
              ) Edit

              a.btn.btn-danger.btn-sm(
                href="/employees/delete/" + emp.id
                onclick="return confirm('Are you sure you want to delete this employee?')"
              ) Delete